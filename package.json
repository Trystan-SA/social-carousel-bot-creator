{
  "name": "postkit",
  "version": "0.1.1",
  "description": "Generate TikTok, Instagram, and X.com carousels from HTML/CSS — themed, scriptable, Claude-Code-friendly.",
  "type": "module",
  "bin": {
    "postkit": "./bin/postkit.js"
  },
  "files": [
    "bin",
    "src",
    "templates",
    "Dockerfile",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "render": "node bin/postkit.js render",
    "new": "node bin/postkit.js new",
    "init": "node bin/postkit.js init",
    "watch": "node bin/postkit.js watch"
  },
  "keywords": [
    "carousel",
    "tiktok",
    "instagram",
    "reels",
    "social-media",
    "puppeteer",
    "html-to-png",
    "claude-code"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Trystan-SA/postkit.git"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chokidar": "^4.0.1",
    "puppeteer": "^24.0.0"
  }
}
